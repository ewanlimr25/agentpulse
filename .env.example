# AgentPulse environment variables.
# Copy to `.env` and edit for your setup. All values shown are the in-code defaults;
# any line you leave commented falls back to the default.

# ── Backend API (backend/) ────────────────────────────────────────────────────

# HTTP_HOST=0.0.0.0
# HTTP_PORT=8080

# Set to "production" to tighten CORS and disable dev conveniences.
# Leaving unset or "development" enables dev mode (Access-Control-Allow-Origin: *).
# APP_ENV=development

# Comma-separated list of origins allowed to call the API (production only).
# CORS_ALLOWED_ORIGINS=https://agentpulse.example.com,https://app.example.com

# Postgres connection string (topology, projects, budgets, alerts, evals, tokens).
# POSTGRES_DSN=postgres://agentpulse:agentpulse@localhost:5432/agentpulse?sslmode=disable

# ClickHouse connection (spans, metrics, sessions, user aggregates).
# CLICKHOUSE_ADDR=localhost:9000
# CLICKHOUSE_DATABASE=agentpulse
# CLICKHOUSE_USER=agentpulse
# CLICKHOUSE_PASSWORD=agentpulse

# Object storage for span payload offload (>8 KB payloads). MinIO works as a
# local drop-in for S3 via `make dev-up`.
# S3_ENDPOINT=http://localhost:9090
# S3_BUCKET=agentpulse-spans
# S3_ACCESS_KEY=agentpulse
# S3_SECRET_KEY=agentpulse
# S3_ENFORCE_HTTPS=false    # set true in production

# ── LLM providers (evals + prompt playground) ─────────────────────────────────
# At least one is required to run eval judges or re-send spans from the
# playground. If all three are unset, evals are disabled.
# ANTHROPIC_API_KEY=sk-ant-api03-...
# OPENAI_API_KEY=sk-...
# GOOGLE_AI_API_KEY=...

# ── Notifications ─────────────────────────────────────────────────────────────

# Browser push (Web Push / VAPID). Generate with:
#   npx web-push generate-vapid-keys
# VAPID_SUBJECT must be a mailto: or https: URI per RFC 8292.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com

# Resend transactional email (daily alert digest).
# RESEND_API_KEY=re_...
# EMAIL_FROM_ADDRESS=alerts@your-domain.com

# ── CLI (backend/agentpulse-cli) ──────────────────────────────────────────────

# The CLI connects to the backend with a project Bearer token.
# AGENTPULSE_API_URL=http://localhost:8080
# AGENTPULSE_API_KEY=<paste the api_key from POST /api/v1/projects>

# Legacy alias accepted by older commands.
# AGENTPULSE_ENDPOINT=http://localhost:8080

# Override pricing table location (normally baked into the binary).
# MODEL_PRICING_PATH=/etc/agentpulse/model_pricing.yaml

# ── Frontend (web/) ───────────────────────────────────────────────────────────

# Base URL the Next.js app uses for API calls. Must be reachable from the
# browser (not just the Next.js server).
# NEXT_PUBLIC_API_URL=http://localhost:8080
